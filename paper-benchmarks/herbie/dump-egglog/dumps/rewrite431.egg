(constructor do-lower (M String) MTy :unextractable)
(constructor do-lift (MTy) M :unextractable)
(ruleset lower)
(ruleset lift)
(ruleset unsound)
(function bad-merge? () bool :merge (or old new))
(ruleset bad-merge-rule)
(set (bad-merge?) false)
(rule
 ((= (Num c1) (Num c2)) (!= c1 c2))
 ((set (bad-merge?) true))
 :ruleset
 bad-merge-rule)
(rule
 ((= e (Var "x")))
 ((union (do-lower e "sym_binary64") (Var_sym_binary64 "x")))
 :ruleset
 lower)
(rule
 ((= e (Var "y")))
 ((union (do-lower e "sym_binary64") (Var_sym_binary64 "y")))
 :ruleset
 lower)
(rule
 ((= e (Var_sym_binary64 "x")))
 ((union (do-lift e) (Var "x")))
 :ruleset
 lift)
(rule
 ((= e (Var_sym_binary64 "y")))
 ((union (do-lift e) (Var "y")))
 :ruleset
 lift)
(constructor const1 () M :unextractable)
(constructor const2 () M :unextractable)
(constructor const3 () MTy :unextractable)
(constructor const4 () MTy :unextractable)
(constructor const5 () M :unextractable)
(constructor const6 () M :unextractable)
(constructor const7 () M :unextractable)
(ruleset run-extract-commands)
(rule
 ()
 ((let ?sx (Var "x"))
  (union (const1) ?sx)
  (let ?sy (Var "y"))
  (union (const2) ?sy)
  (let ?tx (Var_sym_binary64 "x"))
  (union (const3) ?tx)
  (let ?ty (Var_sym_binary64 "y"))
  (union (const4) ?ty)
  (let ?r1 (Num (bigrat (from-string "1") (from-string "1"))))
  (union (const5) ?r1)
  (let ?r3 (Sub ?r1 ?sy))
  (union (const6) ?r3)
  (let ?r4 (Mul ?sx ?r3))
  (union (const7) ?r4))
 :ruleset
 run-extract-commands)
(run-schedule (repeat 1 run-extract-commands))
